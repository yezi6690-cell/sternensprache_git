<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MindIsle" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mi_primary</item>
        <item name="colorPrimaryVariant">@color/mi_primary</item>
        <item name="colorSecondary">@color/mi_secondary</item>
        <item name="android:windowBackground">@color/xingyue_system_bar</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:navigationBarColor">@color/xingyue_system_bar</item>
        <item name="android:statusBarColor">@color/xingyue_system_bar</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="materialButtonStyle">@style/Widget.MindIsle.Button</item>
    </style>

    <style name="Theme.MindIsle.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:navigationBarColor">@color/mi_secondary</item>
        <item name="android:statusBarColor">@color/mi_primary</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Widget.MindIsle.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/mi_button_radius</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/mi_primary</item>
    </style>
</resources>
