<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <gradient android:angle="0" android:endColor="@color/xingyue_moon_purple_soft" android:startColor="#FCFEFF" />
            <stroke android:width="1.5dp" android:color="@color/xingyue_moon_purple" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#F2FFFDF7" />
            <stroke android:width="1dp" android:color="@color/xingyue_card_stroke" />
            <corners android:radius="26dp" />
        </shape>
    </item>
</selector>
