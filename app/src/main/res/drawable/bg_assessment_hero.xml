<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/xingyue_ripple_blue">
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:centerColor="@color/xingyue_cream"
                android:endColor="@color/xingyue_mint_soft"
