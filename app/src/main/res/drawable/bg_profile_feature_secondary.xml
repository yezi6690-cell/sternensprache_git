<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_moon_purple_soft" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:endColor="@color/xingyue_moon_purple_soft"
                android:startColor="#FBF9FF" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#CEC3EE" />
        </shape>
    </item>
</selector>
