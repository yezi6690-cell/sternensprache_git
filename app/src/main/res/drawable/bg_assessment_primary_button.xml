<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#B8C6D8" />
            <corners android:radius="25dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_primary_blue_deep" />
            <corners android:radius="25dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="0"
                android:endColor="@color/xingyue_moon_purple"
                android:startColor="@color/xingyue_primary_blue" />
            <corners android:radius="25dp" />
        </shape>
    </item>
</selector>
