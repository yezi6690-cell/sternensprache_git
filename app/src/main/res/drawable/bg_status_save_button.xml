<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_primary_blue_deep" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="0" android:endColor="@color/xingyue_moon_purple" android:startColor="@color/xingyue_primary_blue" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</selector>
