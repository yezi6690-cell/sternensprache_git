<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <corners android:radius="18dp" />
            <gradient
                android:angle="0"
                android:endColor="#DCD5FF"
                android:startColor="#D8EAFF" />
            <stroke
                android:width="1dp"
                android:color="@color/xingyue_primary_blue" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="18dp" />
            <solid android:color="#BFFFFFFF" />
            <stroke
                android:width="1dp"
                android:color="@color/xingyue_card_stroke" />
        </shape>
    </item>
</selector>
