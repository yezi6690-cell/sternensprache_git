<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_pressed_blue" />
            <stroke android:width="1dp" android:color="@color/xingyue_primary_blue" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="0" android:endColor="#EAF3FF" android:startColor="#FFFDF7" />
            <stroke android:width="1dp" android:color="@color/xingyue_card_stroke" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
