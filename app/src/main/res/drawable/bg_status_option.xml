<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <gradient android:angle="135" android:endColor="@color/xingyue_moon_purple_soft" android:startColor="#F6FAFF" />
            <corners android:radius="18dp" />
            <stroke android:width="1.5dp" android:color="@color/xingyue_moon_purple" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#BFFFFFFF" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#E3E8F7" />
        </shape>
    </item>
</selector>
