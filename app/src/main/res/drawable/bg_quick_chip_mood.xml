<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_mist_pink_soft" />
            <stroke android:width="1dp" android:color="@color/xingyue_mist_pink" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="0" android:endColor="#FBEAF2" android:startColor="#FFFBFD" />
            <stroke android:width="1dp" android:color="#E9C3D6" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
