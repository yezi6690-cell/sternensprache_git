<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="#FCFDFF" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1.5dp"
                android:color="@color/profile_accent" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#F6F8FE" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/profile_divider" />
        </shape>
    </item>
</selector>
