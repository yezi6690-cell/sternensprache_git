<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_pressed_blue" />
            <stroke android:width="1dp" android:color="@color/xingyue_primary_blue" />
            <corners android:radius="18dp" />
            <padding android:bottom="6dp" android:left="12dp" android:right="12dp" android:top="6dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="0" android:endColor="#EBF4FF" android:startColor="@color/xingyue_cream" />
            <stroke android:width="1dp" android:color="@color/xingyue_card_stroke" />
            <corners android:radius="18dp" />
            <padding android:bottom="6dp" android:left="12dp" android:right="12dp" android:top="6dp" />
        </shape>
    </item>
</selector>
