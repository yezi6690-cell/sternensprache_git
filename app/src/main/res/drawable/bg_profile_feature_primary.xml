<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_pressed_blue" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:endColor="#E6F1FF"
                android:startColor="#FAFDFF" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#B8D0EE" />
        </shape>
    </item>
</selector>
