    </item>
    <item>
        <shape android:shape="oval">
            <gradient android:angle="135" android:endColor="#E8F2FF" android:startColor="#FFFFFF" />
            <stroke android:width="1dp" android:color="#C5D2F6" />
        </shape>
    </item>
</selector>
