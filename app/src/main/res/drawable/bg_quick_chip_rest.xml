<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_mint_soft" />
            <stroke android:width="1dp" android:color="@color/xingyue_mint" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="0" android:endColor="#E9F8F5" android:startColor="#FBFFFE" />
            <stroke android:width="1dp" android:color="#B6DED7" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
