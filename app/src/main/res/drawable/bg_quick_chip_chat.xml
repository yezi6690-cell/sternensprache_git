<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/xingyue_moon_purple_soft" />
            <stroke android:width="1dp" android:color="@color/xingyue_moon_purple" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="0" android:endColor="#F0ECFF" android:startColor="#FCFBFF" />
            <stroke android:width="1dp" android:color="#CFC4F4" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
