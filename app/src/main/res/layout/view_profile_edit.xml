<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/profile_edit_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:visibility="gone">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/profile_edit_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_profile_round_button"
                    android:clickable="true"
                    android:contentDescription="返回我的页面"
                    android:focusable="true"
                    android:foreground="@drawable/bg_profile_menu_ripple"
                    android:gravity="center"
                    android:text="‹"
                    android:textColor="@color/profile_accent_deep"
                    android:textSize="30sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="个人资料"
                        android:textColor="@color/mi_text_main"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="完善你的心屿档案"
                        android:textColor="@color/profile_caption"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_profile_header_companion"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="18dp">

                <FrameLayout
                    android:id="@+id/profile_edit_avatar_button"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:background="@drawable/bg_profile_avatar_ring"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/bg_profile_menu_ripple"
                    android:padding="5dp">

                    <ImageView
                        android:id="@+id/profile_edit_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="修改个人头像"
                        android:scaleType="centerCrop"
                        android:src="@drawable/deco_xingyue_avatar" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="点击更换头像"
                    android:textColor="@color/profile_accent_deep"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView style="@style/ProfileGroupLabel" android:text="基础资料" />

            <LinearLayout style="@style/ProfileEditGroup">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="昵称" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_nickname" style="@style/ProfileEditField" android:hint="请输入昵称" android:inputType="textPersonName" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="个性状态" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_status" style="@style/ProfileEditField" android:hint="写一句此刻的心情" android:inputType="textCapSentences" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="性别" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_gender" style="@style/ProfileEditField" android:hint="可选" android:inputType="text" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="生日" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_birthday" style="@style/ProfileEditField" android:hint="例如 2000-01-01" android:inputType="date" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="家乡" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_hometown" style="@style/ProfileEditField" android:hint="可选" android:inputType="textCapWords" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="个性签名" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_signature" style="@style/ProfileEditField" android:hint="写下想被记住的一句话" android:inputType="textCapSentences" />
            </LinearLayout>

            <TextView style="@style/ProfileGroupLabel" android:text="账号资料" />

            <LinearLayout style="@style/ProfileEditGroup">
                <TextView android:id="@+id/profile_edit_user_id" style="@style/ProfileReadonlyField" android:text="用户ID：user_10001" />
                <View style="@style/ProfileMenuDivider" android:layout_marginStart="12dp" android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/profile_edit_register_time" style="@style/ProfileReadonlyField" android:text="注册时间：--" />
                <View style="@style/ProfileMenuDivider" android:layout_marginStart="12dp" android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/profile_edit_account_status" style="@style/ProfileReadonlyField" android:text="账号状态：正常" />
            </LinearLayout>

            <TextView style="@style/ProfileGroupLabel" android:text="扩展资料（可选）" />

            <LinearLayout style="@style/ProfileEditGroup">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="身份 / 职业" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_identity" style="@style/ProfileEditField" android:hint="例如 设计师、学生、自由职业者" android:inputType="textCapWords" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="学校 / 公司" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_school_company" style="@style/ProfileEditField" android:hint="可选" android:inputType="textCapWords" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="专业 / 方向" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_major_direction" style="@style/ProfileEditField" android:hint="可选" android:inputType="textCapWords" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="组织 / 小组" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_group_organization" style="@style/ProfileEditField" android:hint="可选" android:inputType="textCapWords" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="兴趣标签" android:textColor="@color/profile_caption" android:textSize="12sp" />
                <EditText android:id="@+id/profile_edit_interests" style="@style/ProfileEditField" android:hint="例如 音乐、阅读、旅行" android:inputType="textCapWords" />
            </LinearLayout>

            <TextView
                android:id="@+id/profile_edit_save"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_profile_save_companion"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="保存资料"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
