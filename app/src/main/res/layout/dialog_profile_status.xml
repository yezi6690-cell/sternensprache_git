<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/status_sheet_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_status_sheet"
    android:orientation="vertical"
    android:paddingTop="10dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/profile_outline" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <TextView
            android:id="@+id/status_sheet_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_profile_round_button"
            android:clickable="true"
            android:contentDescription="关闭状态选择"
            android:focusable="true"
            android:gravity="center"
            android:text="×"
            android:textColor="@color/profile_accent_deep"
            android:textSize="25sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设个状态"
                android:textColor="@color/mi_text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="今天想让心屿怎么陪你？"
                android:textColor="@color/profile_caption"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/status_sheet_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_status_icon_badge"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/status_selected_icon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="当前状态图标"
                        android:src="@drawable/ic_status_jellyfish" />
                </FrameLayout>

                <EditText
                    android:id="@+id/status_text_input"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_edit_field"
                    android:hint="写一句今天的状态"
                    android:inputType="textCapSentences"
                    android:maxLength="40"
                    android:maxLines="2"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/mi_text_main"
                    android:textColorHint="@color/profile_caption"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/status_expire_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="end"
                android:text="状态将在 24 小时后自动结束"
                android:textColor="@color/profile_caption"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/status_categories_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/status_clear_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="0.8"
            android:background="@drawable/bg_status_cancel_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="结束状态"
            android:textColor="@color/profile_caption"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/status_save_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1.2"
            android:background="@drawable/bg_status_save_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="保存状态"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
