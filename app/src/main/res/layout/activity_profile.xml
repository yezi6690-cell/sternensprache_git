<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mi_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/mi_page_padding">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/mi_card"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:stateListAnimator="@null">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="78dp"
                        android:layout_height="78dp"
                        android:background="@drawable/bg_avatar"
                        android:gravity="center"
                        android:text="心"
                        android:textColor="@color/mi_text_main"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profile_name_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="心屿用户"
                        android:textColor="@color/mi_text_main"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profile_identity_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="大学生"
                        android:textColor="@color/mi_text_sub"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/profile_student_id_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_tag_inactive"
                        android:text="学号：20260001"
                        android:textColor="@color/mi_text_main"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_soft_panel"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:id="@+id/profile_mood_row"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="个人资料"
                    android:textColor="@color/mi_text_main"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/profile_pet_row"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="二维码"
                    android:textColor="@color/mi_text_main"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/profile_privacy_row"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="主题设置"
                    android:textColor="@color/mi_text_main"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/profile_about_row"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="账号设置"
                    android:textColor="@color/mi_text_main"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/profile_about_app_row"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="关于心屿"
                    android:textColor="@color/mi_text_main"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/mi_card"
        app:itemIconTint="@color/mi_text_sub"
        app:itemTextColor="@color/mi_text_main"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav" />
</LinearLayout>
